[Unit]
Description=Book Downloader Web Server
After=network.target ebookdatabase.service docker.service

[Service]
Type=simple
ExecStart=/home/eclaw/book-downloader-web/backend/venv/bin/python main.py
WorkingDirectory=/home/eclaw/book-downloader-web/backend
Restart=no
Environment="PATH=/home/eclaw/book-downloader-web/backend/venv/bin:/usr/bin:/bin"
Environment="TMPDIR=/home/eclaw/tmp/ocrmypdf"
Environment="BDW_CONFIG_DIR=/home/eclaw/.book-downloader"

[Install]
WantedBy=default.target
