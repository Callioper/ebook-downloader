[Unit]
Description=Agent Ebook Downloader Web Server
After=network.target ebookdatabase.service docker.service

[Service]
Type=simple
ExecStart=/home/{user}/agent-ebook-downloader/backend/venv/bin/python main.py
WorkingDirectory=/home/{user}/agent-ebook-downloader/backend
Restart=no
Environment="PATH=/home/{user}/agent-ebook-downloader/backend/venv/bin:/usr/bin:/bin"
Environment="TMPDIR=/home/{user}/tmp/ocrmypdf"
Environment="BDW_CONFIG_DIR=/home/{user}/.agent-ebook-downloader"

[Install]
WantedBy=default.target
